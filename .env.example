# Database (Neon PostgreSQL)
ConnectionStrings__DefaultConnection=Host=localhost;Port=5432;Database=ecommerce_inventory;Username=postgres;Password=postgres;SSL Mode=Require

# JWT Settings
JwtSettings__SecretKey=YourSuperSecretKeyForJWTTokenSigningMustBeAtLeast32CharsLong!
JwtSettings__Issuer=EcommerceInventoryAPI
JwtSettings__Audience=EcommerceInventoryClients
JwtSettings__AccessTokenExpMinutes=15
JwtSettings__RefreshTokenExpDays=7

# Email (Gmail SMTP)
EmailSettings__Host=smtp.gmail.com
EmailSettings__Port=587
EmailSettings__Username=your-email@gmail.com
EmailSettings__Password=your-app-password
EmailSettings__FromEmail=your-email@gmail.com
EmailSettings__FromName=Ecommerce Inventory System
EmailSettings__EnableSsl=true

# Cloudinary (Image Storage)
CloudinarySettings__CloudName=your-cloud-name
CloudinarySettings__ApiKey=your-api-key
CloudinarySettings__ApiSecret=your-api-secret

# App
AppSettings__BaseUrl=https://localhost:7148
